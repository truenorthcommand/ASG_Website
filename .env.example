# Database Configuration
# Railway MySQL plugin automatically provides DATABASE_URL
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/asg_website

# JWT Secret (required for session tokens)
# Generate a strong random 32+ character string
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
COOKIE_SECRET=your-super-secret-cookie-key-change-this-in-production

# Node Environment
NODE_ENV=production

# Frontend URL (for CORS and redirects)
# In Railway, this will be your Railway domain or custom domain
FRONTEND_URL=https://your-railway-domain.up.railway.app

# Server Port (Railway sets this automatically)
PORT=3000
